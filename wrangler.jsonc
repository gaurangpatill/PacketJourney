{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "packet-journey-api",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "ratelimits": [
    {
      "name": "HTTP_INVESTIGATION_RATE_LIMITER",
      "namespace_id": "2391001",
      "simple": {
        "limit": 20,
        "period": 60,
      },
    },
    {
      "name": "BROWSER_INVESTIGATION_RATE_LIMITER",
      "namespace_id": "2391003",
      "simple": {
        "limit": 3,
        "period": 60,
      },
    },
    {
      "name": "AI_INVESTIGATION_RATE_LIMITER",
      "namespace_id": "2391005",
      "simple": {
        "limit": 8,
        "period": 60,
      },
    },
    {
      "name": "AI_INVESTIGATION_HASH_RATE_LIMITER",
      "namespace_id": "2391006",
      "simple": {
        "limit": 3,
        "period": 60,
      },
    },
  ],
  "browser": {
    "binding": "BROWSER",
  },
  "ai": {
    "binding": "AI",
  },
  "vectorize": [
    {
      "binding": "TECHNICAL_REFERENCES",
      "index_name": "packet-journey-references-v1",
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "packet-journey",
      "migrations_dir": "migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "BROWSER_ARTIFACTS",
      "bucket_name": "packet-journey-browser-artifacts",
    },
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "AI_ENABLED": "true",
    "AI_GATEWAY_ID": "default",
    "AI_MODEL": "llama-3.3-70b-fast",
    "REFERENCE_INDEX_VERSION": "references-v1",
    "REFERENCE_EMBEDDING_MODEL": "@cf/qwen/qwen3-embedding-0.6b",
    "REFERENCE_CORPUS_VERSION": "2026-07-v1",
    "REFERENCE_RETRIEVAL_VERSION": "reference-retrieval-v1",
  },
  "env": {
    "preview": {
      "name": "packet-journey-api-preview",
      "vars": {
        "ENVIRONMENT": "preview",
        "AI_ENABLED": "true",
        "AI_GATEWAY_ID": "default",
        "AI_MODEL": "llama-3.3-70b-fast",
        "REFERENCE_INDEX_VERSION": "references-v1",
        "REFERENCE_EMBEDDING_MODEL": "@cf/qwen/qwen3-embedding-0.6b",
        "REFERENCE_CORPUS_VERSION": "2026-07-v1",
        "REFERENCE_RETRIEVAL_VERSION": "reference-retrieval-v1",
      },
      "ratelimits": [
        {
          "name": "HTTP_INVESTIGATION_RATE_LIMITER",
          "namespace_id": "2391002",
          "simple": {
            "limit": 20,
            "period": 60,
          },
        },
        {
          "name": "BROWSER_INVESTIGATION_RATE_LIMITER",
          "namespace_id": "2391004",
          "simple": {
            "limit": 3,
            "period": 60,
          },
        },
        {
          "name": "AI_INVESTIGATION_RATE_LIMITER",
          "namespace_id": "2391007",
          "simple": {
            "limit": 8,
            "period": 60,
          },
        },
        {
          "name": "AI_INVESTIGATION_HASH_RATE_LIMITER",
          "namespace_id": "2391008",
          "simple": {
            "limit": 3,
            "period": 60,
          },
        },
      ],
      "browser": {
        "binding": "BROWSER",
      },
      "ai": {
        "binding": "AI",
      },
      "vectorize": [
        {
          "binding": "TECHNICAL_REFERENCES",
          "index_name": "packet-journey-references-v1",
        },
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "packet-journey-preview",
          "migrations_dir": "migrations",
        },
      ],
      "r2_buckets": [
        {
          "binding": "BROWSER_ARTIFACTS",
          "bucket_name": "packet-journey-browser-artifacts-preview",
        },
      ],
    },
  },
}
