{
  "name": "packet-journey",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,worker --prefix-colors cyan,magenta \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:web": "vite",
    "dev:worker": "wrangler dev --config wrangler.local.jsonc --port 8787",
    "dev:worker:ai": "wrangler dev --config wrangler.ai-local.jsonc --port 8787",
    "build": "npm run build:web && npm run build:worker",
    "build:web": "tsc -b && vite build",
    "build:worker": "wrangler deploy --dry-run --env=\"\"",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "preview": "vite preview",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:production": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.local.jsonc",
    "db:migrate:preview": "wrangler d1 migrations apply packet-journey-preview --remote --env preview",
    "db:migrate:production": "wrangler d1 migrations apply packet-journey --remote",
    "db:reset:local": "wrangler d1 execute DB --local --config wrangler.local.jsonc --command=\"DROP TABLE IF EXISTS diagnosis_reference_citations; DROP TABLE IF EXISTS diagnosis_reference_runs; DROP TABLE IF EXISTS reference_chunks; DROP TABLE IF EXISTS reference_sources; DROP TABLE IF EXISTS artifact_cleanup_failures; DROP TABLE IF EXISTS investigation_artifacts; DROP TABLE IF EXISTS share_links; DROP TABLE IF EXISTS counterfactual_results; DROP TABLE IF EXISTS ai_diagnoses; DROP TABLE IF EXISTS investigations; DELETE FROM d1_migrations;\" && npm run db:migrate:local",
    "references:ingest": "tsx scripts/references/ingest.ts",
    "references:verify": "tsx scripts/references/verify.ts",
    "test:retrieval": "vitest run src/references src/worker/references",
    "smoke:references": "tsx scripts/references/smoke.ts"
  },
  "dependencies": {
    "ipaddr.js": "^2.4.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tldts": "^7.4.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/playwright": "^1.3.0",
    "@cloudflare/workers-types": "^5.20260717.1",
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.23.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
